{
  "name": "purple-llama-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Alchemist's Descent — a falling-sand action roguelite built on a cellular automata engine",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:findability": "node scripts/verify-findability.mjs",
    "verify:game": "node scripts/verify-game.mjs",
    "perf:scene": "node scripts/perf-scene.mjs",
    "perf:ab": "node scripts/perf-ab-feature.mjs",
    "probe:webgpu-r184": "node scripts/probe-webgpu-r184.mjs",
    "probe:render-backend": "node scripts/probe-render-backend-selection.mjs",
    "probe:webgpu-presentation": "node scripts/probe-webgpu-presentation.mjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,css}\" index.html"
  },
  "dependencies": {
    "three": "0.184.0"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.61.1",
    "@types/node": "^25.9.2",
    "@types/three": "0.184.1",
    "eslint": "^9.0.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
